  "regex_rules": {
    "_nota": "Reglas regex. Cada clave es un patrón regex, el valor es {replace, flags}. Se aplican DESPUÉS de las reglas de string.",
    "(?<![a-zA-ZáéíóúÁÉÍÓÚ])(?<!Xiao )(?<!xiao )(\\d[\\d.,]*)\\s*jin\\b": {
      "replace": "\\1 catties",
      "flags": "IGNORECASE",
      "context": "Unidad de fuerza: N jin → N catties. Solo cuando precede un número."
    },
    "(?i)\\bmaestría\\b(?!\\s+(?:de|en|del))": {
      "replace": "Consumación",
      "context": "En contexto de nivel de técnica marcial, maestría → Consumación."
    }
  }
